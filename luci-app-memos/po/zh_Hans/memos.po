msgid "Memos"
msgstr "Memos"

msgid "Memos - Settings"
msgstr "Memos - 设置"

msgid "Self-hosted note-taking. Binary is fetched from upstream on demand."
msgstr "自托管笔记服务。二进制按需从上游下载。"

msgid "Settings are passed to the memos binary as command-line flags by the init script. Some options (driver, mirror, release channel) only affect how the package downloads or runs memos and are not memos CLI flags themselves."
msgstr "设置由 init 脚本作为命令行参数传给 memos 二进制。部分选项（数据库驱动、下载镜像、发布通道）仅影响本包的下载或运行方式，并非 memos 自身 CLI 参数。"

msgid "Service Status"
msgstr "服务状态"

msgid "Running"
msgstr "运行中"

msgid "Not running"
msgstr "未运行"

msgid "Binary missing"
msgstr "二进制缺失"

msgid "(service disabled)"
msgstr "（服务未启用）"

msgid "Binary Path"
msgstr "二进制路径"

msgid "Local Version"
msgstr "本地版本"

msgid "not installed"
msgstr "未安装"

msgid "Remote Version"
msgstr "远程版本"

msgid "unavailable"
msgstr "不可用"

msgid "Architecture"
msgstr "架构"

msgid "Binary Action"
msgstr "二进制操作"

msgid "Download binary"
msgstr "下载二进制"

msgid "Update to %s"
msgstr "更新至 %s"

msgid "Already up-to-date"
msgstr "已是最新版"

msgid "Check again"
msgstr "重新检查"

msgid "Cancel update"
msgstr "取消更新"

msgid "Open Memos"
msgstr "打开 Memos"

msgid "Unix socket mode — open via reverse proxy"
msgstr "Unix 套接字模式 — 请通过反向代理访问"

msgid "Update Log"
msgstr "更新日志"

msgid "(no update running)"
msgstr "（当前无更新任务）"

msgid "Checking..."
msgstr "检查中…"

msgid "Working..."
msgstr "处理中…"

msgid "Cancelling..."
msgstr "取消中…"

msgid "Update failed. See the update log below."
msgstr "更新失败，请查看下方更新日志。"

msgid "General"
msgstr "通用"

msgid "Database"
msgstr "数据库"

msgid "Download Mirror"
msgstr "下载镜像"

msgid "Advanced"
msgstr "高级"

msgid "Enabled"
msgstr "启用"

msgid "Enable the memos service. When disabled, the init script will not start memos."
msgstr "启用 memos 服务。关闭时 init 脚本不会启动 memos。"

msgid "Listen address"
msgstr "监听地址"

msgid "Address the HTTP server binds to. Empty means all interfaces (0.0.0.0)."
msgstr "HTTP 服务绑定的地址。留空表示所有接口（0.0.0.0）。"

msgid "Listen port"
msgstr "监听端口"

msgid "Port the HTTP server listens on. Overridden if a Unix socket is configured."
msgstr "HTTP 服务监听端口。若配置了 Unix 套接字则忽略此项。"

msgid "Data directory"
msgstr "数据目录"

msgid "Where memos stores its SQLite database and uploaded attachments. Must be on a writable, persistent filesystem; data on a tmpfs will be lost on reboot."
msgstr "memos 存放 SQLite 数据库与附件的位置。须为可写持久文件系统；放在 tmpfs 上重启后会丢失。"

msgid "Path must be absolute."
msgstr "路径必须为绝对路径。"

msgid "Binary path"
msgstr "二进制路径"

msgid "Where the downloaded memos binary is stored. Re-download via the Overview page."
msgstr "下载的 memos 二进制存放路径。可在概览页重新下载。"

msgid "Log level"
msgstr "日志级别"

msgid "Verbosity of the memos log output (sent to syslog by procd)."
msgstr "memos 日志详细程度（由 procd 送入 syslog）。"

msgid "Database driver"
msgstr "数据库驱动"

msgid "SQLite needs no extra packages and is the default for router scenarios."
msgstr "SQLite 无需额外软件包，适合路由器场景，为默认选项。"

msgid "SQLite (embedded, recommended)"
msgstr "SQLite（内置，推荐）"

msgid "MySQL / MariaDB"
msgstr "MySQL / MariaDB"

msgid "PostgreSQL"
msgstr "PostgreSQL"

msgid "DSN"
msgstr "DSN"

msgid "Database source name for the chosen driver. Required when driver is not SQLite. Example (MySQL): user:pass@tcp(127.0.0.1:3306)/memos?parseTime=true Example (Postgres): postgres://user:pass@127.0.0.1:5432/memos?sslmode=disable"
msgstr "所选驱动的数据库连接串。非 SQLite 时必填。示例（MySQL）：user:pass@tcp(127.0.0.1:3306)/memos?parseTime=true 示例（Postgres）：postgres://user:pass@127.0.0.1:5432/memos?sslmode=disable"

msgid "Download mirror"
msgstr "下载镜像"

msgid "When GitHub is not reachable from your region, pick a mirror prefix to proxy binary download URLs. The GitHub API is always accessed directly. Mirror availability is not guaranteed; switch to \"Custom\" if the built-in ones stop working."
msgstr "当本地区无法直连 GitHub 时，选择镜像前缀以代理二进制下载地址。GitHub API 始终直连。镜像可用性不保证；内置失效时可改用「自定义」。"

msgid "Official (direct GitHub)"
msgstr "官方（直连 GitHub）"

msgid "ghproxy.com"
msgstr "ghproxy.com"

msgid "gh-proxy.com"
msgstr "gh-proxy.com"

msgid "hub.gitmirror.com"
msgstr "hub.gitmirror.com"

msgid "github.moeyy.xyz"
msgstr "github.moeyy.xyz"

msgid "Custom"
msgstr "自定义"

msgid "Custom mirror prefix"
msgstr "自定义镜像前缀"

msgid "A prefix prepended to github.com URLs. Must end with \"/\". Leave empty to disable the custom prefix."
msgstr "拼接到 github.com URL 前的前缀，须以「/」结尾。留空则不使用自定义前缀。"

msgid "Must be a full URL ending with \"/\"."
msgstr "必须是以「/」结尾的完整 URL。"

msgid "Release channel"
msgstr "发布通道"

msgid "Stable points at the GitHub releases/latest endpoint (recommended). Beta pulls the newest release (including pre-releases) for those who want to test."
msgstr "稳定版对应 GitHub releases/latest（推荐）。测试版取最新发布（含预发布），供尝鲜使用。"

msgid "Stable"
msgstr "稳定版"

msgid "Beta / pre-release"
msgstr "测试版 / 预发布"

msgid "Daily auto-update"
msgstr "每日自动更新"

msgid "Install a daily 3:30 AM cron job that runs memos.sh update. Only the memos binary is replaced; your data is untouched."
msgstr "安装每日凌晨 3:30 的 cron 任务运行 memos.sh update。仅替换二进制，数据不受影响。"

msgid "Instance URL"
msgstr "实例 URL"

msgid "Public URL of your memos instance, e.g. https://memos.example.com. Setting this enables the \"public\" access mode (anonymous read access)."
msgstr "memos 实例的公开 URL，例如 https://memos.example.com。设置后启用「公开」访问模式（匿名可读）。"

msgid "Unix socket"
msgstr "Unix 套接字"

msgid "Path to a Unix socket; takes precedence over --addr and --port."
msgstr "Unix 套接字路径；优先于 --addr 与 --port。"

msgid "Demo mode"
msgstr "演示模式"

msgid "Enable memos' built-in demo mode. Seeded data, intended for testing only."
msgstr "启用 memos 内置演示模式。含种子数据，仅供测试。"

msgid "Private webhooks"
msgstr "私有 Webhook"

msgid "Allow webhook URLs to resolve to private / reserved IP ranges. Off by default."
msgstr "允许 Webhook URL 解析到私有/保留 IP 段。默认关闭。"

msgid "Run as user"
msgstr "运行用户"

msgid "Drop privileges to this user before exec. Empty = root. Make sure the data dir is writable by this user."
msgstr "启动前降权到此用户。留空为 root。请确保该用户可写数据目录。"

msgid "Run as group"
msgstr "运行用户组"

msgid "Drop privileges to this group before exec. Empty = root."
msgstr "启动前降权到此用户组。留空为 root。"

msgid "GOGC"
msgstr "GOGC"

msgid "Go garbage-collector aggressiveness (heap growth percentage). Empty = unset/100."
msgstr "Go 垃圾回收激进程度（堆增长百分比）。留空表示未设置/100。"

msgid "GOMAXPROCS"
msgstr "GOMAXPROCS"

msgid "Maximum number of OS threads for Go user code. Empty = match available CPUs."
msgstr "Go 用户代码可用的最大 OS 线程数。留空表示匹配可用 CPU。"

msgid "GOMEMLIMIT (MiB)"
msgstr "GOMEMLIMIT（MiB）"

msgid "Soft memory limit for the Go runtime in MiB. Empty = no limit."
msgstr "Go 运行时软内存上限（MiB）。留空表示不限制。"
