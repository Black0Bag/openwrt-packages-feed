{
	"luci-app-memos": {
		"description": "授予 Memos LuCI 应用所需权限",
		"read": {
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "memos" ],
			"file": {
				"/tmp/memos_update.log": [ "read" ]
			}
		},
		"write": {
			"file": {
				"/usr/share/memos/memos.sh check": [ "exec" ],
				"/usr/share/memos/memos.sh version": [ "exec" ],
				"/usr/share/memos/memos.sh download": [ "exec" ],
				"/usr/share/memos/memos.sh update": [ "exec" ],
				"/usr/share/memos/memos.sh cancel": [ "exec" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "memos" ]
		}
	}
}
