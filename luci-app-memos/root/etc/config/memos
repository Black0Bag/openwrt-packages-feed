config memos 'memos'
	option enabled '0'
	option addr ''
	option port '8081'
	option data '/etc/memos'
	option binpath '/usr/bin/memos'
	option log_level 'info'
	option driver 'sqlite'
	option dsn ''
	option instance_url ''
	option unix_sock ''
	option demo '0'
	option allow_private_webhooks '0'
	option release_channel 'stable'
	option mirror 'official'
	option mirror_custom ''
	option cron_autoupdate '0'
