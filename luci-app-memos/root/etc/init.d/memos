#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: GPL-2.0-only
#
# init script for the memos service. procd-based.
#
# On start, if the configured binpath does not exist, trigger memos.sh
# download in the background so the binary materialises itself (e.g. first
# boot after a fresh sysupgrade, or after a manual rm of the binary).

USE_PROCD=1
START=95
STOP=01

CONFIGURATION=memos
PROG=/usr/bin/memos
UPDATE_SCRIPT=/usr/share/memos/memos.sh
CRON_FILE=/etc/crontabs/root

# Optional extra commands exposed to /etc/init.d/memos <cmd>.
extra_command "isrunning" "report whether memos is running"

# --- helpers --------------------------------------------------------------
memos_get() { uci -q get "${CONFIGURATION}.${CONFIGURATION}.$1" 2>/dev/null; }
memos_getd() { local v; v="$(memos_get "$1")"; echo "${v:-$2}"; }

# Build the argv for the memos binary from UCI options.
build_args() {
	local args=""
	local addr port data driver dsn instance_url unix_sock log_level demo allow_private

	addr=$(memos_get addr)
	port=$(memos_getd port 8081)
	data=$(memos_getd data /etc/memos)
	driver=$(memos_getd driver sqlite)
	dsn=$(memos_get dsn)
	instance_url=$(memos_get instance_url)
	unix_sock=$(memos_get unix_sock)
	log_level=$(memos_getd log_level info)
	demo=$(memos_get demo)
	allow_private=$(memos_get allow_private_webhooks)

	# unix_sock overrides addr/port in memos itself, so emit it first when set.
	if [ -n "$unix_sock" ]; then
		args="$args --unix-sock $unix_sock"
	else
		[ -n "$addr" ] && args="$args --addr $addr"
		args="$args --port $port"
	fi

	args="$args --data $data"
	args="$args --driver $driver"

	if [ "$driver" != "sqlite" ] && [ -n "$dsn" ]; then
		args="$args --dsn $dsn"
	fi

	[ -n "$instance_url" ] && args="$args --instance-url $instance_url"
	[ "$demo" = "1" ] && args="$args --demo"
	[ "$allow_private" = "1" ] && args="$args --allow-private-webhooks"
	args="$args --log-level $log_level"

	echo "$args"
}

# --- cron / autoupdate ----------------------------------------------------
# If UCI option cron_autoupdate=1 we tell cron to run `memos.sh update` daily.
sync_cron() {
	local findstr default_line enabled autoupdate
	enabled=$(memos_getd enabled 0)
	autoupdate=$(memos_getd cron_autoupdate 0)
	findstr="$UPDATE_SCRIPT update"
	default_line="30 3 * * * $findstr >/dev/null 2>&1"

	mkdir -p "$(dirname "$CRON_FILE")" 2>/dev/null
	[ -f "$CRON_FILE" ] || : > "$CRON_FILE"

	# Strip any existing memos lines, then re-add fresh.
	sed -i "/$UPDATE_SCRIPT/d" "$CRON_FILE" 2>/dev/null

	if [ "$enabled" = "1" ] && [ "$autoupdate" = "1" ]; then
		echo "$default_line" >> "$CRON_FILE"
		log_cron_restart
	fi
}

log_cron_restart() {
	/etc/init.d/cron enabled 2>/dev/null && /etc/init.d/cron restart >/dev/null 2>&1 || true
}

# --- procd service -------------------------------------------------------
start_service() {
	local enabled binpath data

	enabled=$(memos_getd enabled 0)
	binpath=$(memos_getd binpath /usr/bin/memos)
	data=$(memos_getd data /etc/memos)

	sync_cron

	if [ "$enabled" = "0" ]; then
		# Make sure cron knows the autoupdate entry has to go.
		return 0
	fi

	# Ensure the data dir exists (memos needs it before it accepts the flag).
	mkdir -p "$data" 2>/dev/null

	# If the binary is missing, do not fail the whole procd boot - trigger the
	# download in the background and let the user reload LuCI to watch progress.
	if [ ! -x "$binpath" ]; then
		logger -t memos "binary $binpath not found, scheduling background download"
		( $UPDATE_SCRIPT download >/tmp/memos_update.log 2>&1 && \
		  { logger -t memos "download completed, starting service"; start_service; } \
		  || logger -t memos "background download failed, see /tmp/memos_update.log" ) &
		return 0
	fi

	local args user group gc maxprocs memlimit tz
	args=$(build_args)
	user=$(memos_get user)
	group=$(memos_get group)
	gc=$(memos_getd gc 0)
	maxprocs=$(memos_getd maxprocs 0)
	memlimit=$(memos_getd memlimit 0)

	# Inherit timezone if the router has one (most standalone routers do).
	tz=""
	[ -f /etc/TZ ] && tz=$(cat /etc/TZ 2>/dev/null)
	[ -z "$tz" ] && [ -f /var/etc/TZ ] && tz=$(cat /var/etc/TZ 2>/dev/null)

	procd_open_instance
	procd_set_param command "$binpath" $args
	procd_set_param respawn 3600 5 5
	procd_set_param stderr 1
	procd_set_param limits core=unlimited nofile=65535
	[ -n "$user" ]  && procd_set_param user  "$user"
	[ -n "$group" ] && procd_set_param group "$group"
	[ -n "$tz" ] && procd_set_param env TZ="$tz"
	[ "$gc" != "0" ]       && procd_set_param env GOGC="$gc"
	[ "$maxprocs" != "0" ] && procd_set_param env GOMAXPROCS="$maxprocs"
	[ "$memlimit" != "0" ] && procd_set_param env GOMEMLIMIT="${memlimit}MiB"
	procd_set_param file /etc/config/memos
	procd_close_instance

	logger -t memos "service started (bin=$binpath args=$args)"
}

reload_service() { stop; sleep 1; start; }

stop_service() { sync_cron; logger -t memos "service stopped"; }

service_triggers() {
	procd_add_reload_trigger "$CONFIGURATION"
}

isrunning() {
	config_load "$CONFIGURATION"
	local binpath
	binpath=$(memos_getd binpath /usr/bin/memos)
	[ -x "$binpath" ] || { echo "no bin"; return 2; }
	if pgrep -f "${binpath##*/}" >/dev/null 2>&1; then
		echo "running"
		return 0
	fi
	echo "not run"
	return 1
}

boot() {
	rc_procd start
}
